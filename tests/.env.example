# Copy to .env and fill in values

# Server under test
LUDO_SERVER_URL=http://localhost:3002
LUDO_NAMESPACE=/ludo_v2

# Test user IDs (must exist in DB or use mock mode)
TEST_USER_1_ID=10001
TEST_USER_2_ID=10002
TEST_USER_3_ID=10003
TEST_USER_4_ID=10004

# Set to 1 to bypass Laravel sync (pure socket test, no DB required)
MOCK_LARAVEL=1

# Network proxy port (for latency/packet tests)
PROXY_PORT=3099

# Appium
APPIUM_SERVER_URL=http://localhost:4723
ANDROID_APK_PATH=../build/ludo.apk
ANDROID_DEVICE_NAME=emulator-5554
ANDROID_APP_PACKAGE=com.rox.ludo
ANDROID_APP_ACTIVITY=com.unity3d.player.UnityPlayerActivity

# Timeouts (ms)
CONNECT_TIMEOUT=8000
GAME_START_TIMEOUT=15000
TURN_TIMEOUT=20000
RESULT_TIMEOUT=120000
