APP_NAME=GamesBackend
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_PUBLIC_VERSION=1.0.0

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=games_backend
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=games_backend

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

NODE_SERVER_URL=http://127.0.0.1:3000
NODE_SERVER_TIMEOUT=5
INTERNAL_API_TOKEN=
LUDO_SOCKET_NAMESPACE=/ludo
LUDO_DEFAULT_GAME_MODE=classic
LUDO_ALLOW_BOTS_IN_PUBLIC_ROOMS=true
LUDO_ALLOW_BOTS_IN_TOURNAMENTS=false
LUDO_BOT_FILL_AFTER_SECONDS=8
LUDO_MIN_REAL_PLAYERS_TO_START=1
LUDO_DEFAULT_MAX_PLAYERS=4

UNITY_MIN_SUPPORTED_VERSION=1.0.0
UNITY_CURRENT_VERSION=1.0.0
UNITY_FORCE_UPDATE=false
GAME_SEED_LUDO_ONLY_VISIBLE=true
MAINTENANCE_API_ENABLED=false
MAINTENANCE_GAMEPLAY_ENABLED=false
FEATURE_TOURNAMENTS_ENABLED=true

API_DEFAULT_VERSION=v1
API_PREFIX=api
ADMIN_API_PREFIX=admin/api

AUTH_GUARD_API=sanctum
AUTH_GUARD_ADMIN=sanctum
ADMIN_SEED_NAME=Super Admin
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=password123
